{
  "name": "aivm-lm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Agent VM for Lost-Media Hunting — see VM_design.md",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "test": "node --test --disable-warning=ExperimentalWarning",
    "typecheck": "tsc -p packages/casefile/tsconfig.json && tsc -p packages/artifacts/tsconfig.json && tsc -p packages/acquisition/tsconfig.json && tsc -p packages/recon/tsconfig.json",
    "demo:casefile": "node --disable-warning=ExperimentalWarning packages/casefile/examples/demo.ts",
    "demo:artifacts": "node --disable-warning=ExperimentalWarning packages/artifacts/examples/demo.ts",
    "demo:acquisition": "node --disable-warning=ExperimentalWarning packages/acquisition/examples/demo.ts",
    "demo:recon": "node --disable-warning=ExperimentalWarning packages/recon/examples/demo.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
